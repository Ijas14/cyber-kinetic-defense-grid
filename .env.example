# Cyber-Kinetic Defense Grid — LLM Configuration
# Copy to .env and source before running: source .env && cargo run --release

# Lemonade model name (must match what's loaded in Lemonade)
CKDG_MODEL=Qwen3.5-2B-GGUF

# Lemonade OpenAI-compatible chat completions endpoint
CKDG_LLM_ENDPOINT=http://localhost:8000/v1/chat/completions

# LLM sampling temperature (lower = more deterministic)
CKDG_LLM_TEMPERATURE=0.3

# Maximum tokens the LLM will generate per explanation
CKDG_LLM_MAX_TOKENS=150
